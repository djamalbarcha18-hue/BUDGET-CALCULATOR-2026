  // معالج إدخال المفتاح (In-App Setup Wizard)
  setupTitle:      '🔑 إعداد المساعد المالي الذكي',
  setupErrEmpty:   'الرجاء لصق مفتاح Gemini أوّلاً.',
  setupErrInvalid: 'المفتاح غير صالح أو مرفوض. تأكّد من نسخه كاملاً من Google AI Studio ثمّ أعد المحاولة.',
